{
    "manifest_version": 3,
    "name": "Anki Card Wizard",
    "version": "1.0",
    "description": "Add Anki card from your web page.",
    "content_scripts": [
      {
        "js": ["content.js"],
        "matches": ["<all_urls>"]
      }
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
    },
    "permissions": ["storage", "activeTab", "scripting"]
  }
  